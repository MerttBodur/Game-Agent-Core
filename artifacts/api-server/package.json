{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development pnpm run build && cross-env NODE_ENV=development pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "test": "tsx --test src/lib/catalog.test.ts src/lib/rag/indexer.test.ts src/lib/rag/bm25.test.ts src/lib/rag/retriever.test.ts src/services/scoring.test.ts src/agent/steps/feasibility.test.ts src/agent/steps/pickEngineRag.test.ts src/agent/steps/recommendCategory.test.ts src/agent/steps/scoreStack.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "rag:index": "tsx ./src/scripts/indexRag.ts",
    "rag:eval": "tsx ./src/scripts/ragEval.ts"
  },
  "dependencies": {
    "@langchain/community": "^1.1.29",
    "@langchain/core": "^1.1.49",
    "@langchain/openai": "^1.4.7",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "chromadb": "^3.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "langchain": "^1.4.5",
    "mysql2": "^3.11.0",
    "openai": "^6.34.0",
    "pino": "^9",
    "pino-http": "^10",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
