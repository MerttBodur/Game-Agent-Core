# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# build.mjs copies src/data into these mirror dirs at build time (runtime needs them next to dist)
artifacts/data/
artifacts/api-server/data/

# generated by the advisor eval harness (src/agent/advisorEval.ts)
artifacts/api-server/eval-results/

# dependencies
node_modules

# local environment
.env
.env.local
.env.*.local

# Claude Code / MCP local config
.mcp.json
.claude/
.playwright-mcp/

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

